# Supabase Configuration Template
# Copy this file to .env and fill in your values
# cp .env.supabase.example .env

# ===================================
# REQUIRED: Supabase Database
# ===================================
# Get from: https://app.supabase.com/project/_/settings/database
# Go to Settings → Database → Connection pool → Copy URI
# Use connection pooling (port 6543) for production

DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"


# ===================================
# REQUIRED: JWT Configuration
# ===================================
# Generate secure secret: openssl rand -base64 32
# Must be at least 32 characters for security

JWT_SECRET="your-super-secret-jwt-key-min-32-characters-long-change-this"
JWT_EXPIRES_IN="7d"


# ===================================
# OPTIONAL: Server Configuration
# ===================================

PORT=3001
LOG_LEVEL=info
CORS_ORIGIN="*"


# ===================================
# OPTIONAL: Supabase Storage (for file uploads)
# ===================================
# Get from: https://app.supabase.com/project/_/settings/api

# SUPABASE_URL="https://[PROJECT_REF].supabase.co"
# SUPABASE_ANON_KEY="your-anon-key"


# ===================================
# FRONTEND: Next.js Configuration
# ===================================
# For local development
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"

# For production deployment (update with your actual URL)
# NEXT_PUBLIC_API_URL="https://maintix-api-xxxxxx-uc.a.run.app/api/v1"
