{
  "name": "Maintix",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-Property Maintenance Workflow Platform",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @maintix/database db:generate",
    "db:migrate": "pnpm --filter @maintix/database db:migrate",
    "db:push": "pnpm --filter @maintix/database db:push",
    "db:reset": "pnpm --filter @maintix/database db:reset",
    "db:seed": "pnpm --filter @maintix/database db:seed",
    "db:studio": "pnpm --filter @maintix/database db:studio"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/supertest": "^7.2.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.13"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20.0.0"
  }
}
